# Built ONCE on a connected host by scripts/build-app-assets.sh, then saved to
# assets/app/ as an offline image tarball. The air-gapped cluster only ever
# runs the prebuilt image — it never builds or pulls anything.
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app.py wsgi.py ./

# Run as a non-root user (works with RKE2's restricted defaults / SELinux).
RUN useradd --uid 10001 --no-create-home --shell /usr/sbin/nologin appuser
USER 10001

EXPOSE 8080

# 2 workers is plenty for a hello-world; threads help with the DB wait.
CMD ["gunicorn", "--bind", "0.0.0.0:8080", "--workers", "2", \
     "--threads", "4", "--timeout", "90", "wsgi:app"]
